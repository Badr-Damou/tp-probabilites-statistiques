.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Matplotlib cache
.matplotlib_cache/

# Temporary files
tmp/
*.tmp
*.log

# Intermediate report rendering
output/pdf/*.html

# IDE and operating-system files
.vscode/
.idea/
.DS_Store
Thumbs.db
